{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES2022",
    "moduleResolution": "bundler",
    "checkJs": true,
    "ignoreDeprecations": "6.0",
    "noImplicitAny": false,
    "strictNullChecks": false,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "jsx": "preserve",
    "baseUrl": "./src",
    "paths": {
      "@/*": ["*"]
    }
  },
  "include": ["src/**/*.js", "src/**/*.jsx", "src/types/**/*.d.ts"],
  "exclude": ["node_modules", "dist", "src/**/__tests__/**", "src/**/*.test.js", "src/**/*.test.jsx"]
}
