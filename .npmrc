# legacy-peer-deps (#2088, modo campo): @tensorflow-models/speech-commands@0.5.4
# declara peerDependencies contra @tensorflow/tfjs-core|layers|converter ^3.x,
# pero el runtime real usa @tensorflow/tfjs 4.22 (vendoreado en public/vendor
# para el navegador; los paquetes npm solo alimentan los scripts de
# entrenamiento en scripts/wake-word/). Sin esto, `npm ci`/`npm install`
# aborta con ERESOLVE por el rango de peer desactualizado de speech-commands.
# La lib on-device funciona igual con tfjs 4.x (API estable de speech-commands).
legacy-peer-deps=true
