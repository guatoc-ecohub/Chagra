{
  "name": "chagra",
  "private": true,
  "version": "1.0.55",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vitest run && node scripts/validate-catalog-consistency.mjs --report-only",
    "prebuild": "node scripts/build-catalog-sqlite.mjs && node scripts/generate-cycle-content-manifest.mjs && node scripts/gen-chagra-stats.mjs",
    "build": "vite build",
    "build:prod": "node scripts/build-prod.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "coverage": "vitest run --coverage",
    "audit:bundle": "node scripts/audit-bundle.mjs",
    "grafo:snapshot": "node scripts/snapshot-grafo-crecimiento.mjs",
    "gen:stats": "node scripts/gen-chagra-stats.mjs",
    "validate:ngsi": "node scripts/export-ngsi-ld.mjs",
    "hooks:install": "lefthook install",
    "tsc:check": "tsc --noEmit -p jsconfig.json",
    "perf-budget": "node scripts/check-perf-budget.mjs",
    "wake-word:vendor-libs": "node scripts/wake-word/vendor-libs.mjs",
    "wake-word:generate-samples": "node scripts/wake-word/generate-samples.mjs",
    "wake-word:train": "node scripts/wake-word/train-model.mjs",
    "wake-word:smoke": "node tests/e2e-real/modo-campo-wakeword.smoke.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
